# Sample environment for pointing a fleet at a shared Postgres backend.
#
# Source this (or set the equivalent in your deployment manifest) in
# every app replica AND in the aggregator-worker. The app replicas
# write runs; the worker projects totals for the whole fleet.
#
#   set -a && . ./postgres-fleet.env && set +a

# Connection string read by PostgresStorage when no dsn= is passed.
# Any libpq URL or key/value DSN works. Prefer a least-privilege role
# that can INSERT/UPDATE the inkfoot tables and run migrations once.
INKFOOT_PG_DSN=postgresql://app:CHANGE_ME@db.internal:5432/inkfoot

# Connection-pool bounds per process (defaults: min 1 / max 4). Size
# max to your per-replica concurrency; the pool is shared across the
# shim hot path and any worker threads in the same process.
INKFOOT_PG_POOL_MIN=1
INKFOOT_PG_POOL_MAX=8

# Aggregator sweep cadence in milliseconds (default 500). The same
# variable the SQLite in-process aggregator honours.
INKFOOT_AGGREGATOR_INTERVAL_MS=500

# --- App replicas ---------------------------------------------------
# inkfoot.instrument(storage=PostgresStorage())  # DSN from the env above
# On this backend the in-process aggregator thread does NOT start;
# the worker below owns projection.

# --- Aggregator daemon ----------------------------------------------
# Run one per deployment (more than one is safe — see below):
#   inkfoot aggregator-worker
#
# Each sweep is wrapped in a Postgres advisory lock, so when several
# workers run for availability exactly one projects at a time and the
# rest stand by. The advisory lock is cluster-wide, not schema-scoped.
#
# Liveness probe (non-zero exit if the last sweep is too old):
#   inkfoot aggregator-worker --health --max-age-s 60
